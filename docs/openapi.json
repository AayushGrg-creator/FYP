{
  "openapi": "3.0.0",
  "info": {
    "title": "TaskTide API",
    "version": "1.0.0",
    "description": "API documentation for the TaskTide freelance marketplace platform."
  },
  "servers": [
    {
      "url": "http://localhost:5000/api/v1",
      "description": "Development server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "email": { "type": "string" },
          "role": { "type": "string", "enum": ["client", "freelancer", "admin"] }
        }
      }
    }
  },
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Authenticate user",
        "responses": {
          "200": { "description": "Successful login" }
        }
      }
    },
    "/projects": {
      "get": {
        "summary": "List all available projects",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "A list of projects" }
        }
      }
    }
  }
}